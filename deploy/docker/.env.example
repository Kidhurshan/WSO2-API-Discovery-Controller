# Environment variables for the bundled docker-compose deployment.
#
# Copy to .env (in this same directory) before running `docker compose up`:
#   cp .env.example .env
#
# .env is gitignored — never commit it. Rotate by editing .env and running
# `docker compose up -d` (compose detects the change and restarts both
# containers cleanly).
#
# Loaded into BOTH containers:
#   • postgres reads POSTGRES_DB/USER/PASSWORD at first init to create the
#     database, role, and password.
#   • adc reads these env vars AND (ADC_MODE, POSTGRES_HOST). ADC's config
#     loader expands ${VAR} references in /etc/adc/config.toml at startup.
#
# ADC_MODE and POSTGRES_HOST are set to the bundled-Docker defaults below —
# do NOT edit them unless you're switching to external PostgreSQL, in which
# case use docker-compose.external-db.yml instead.
#
# IMPORTANT: changing POSTGRES_PASSWORD after the first `docker compose up`
# does NOT update the existing postgres role — it only takes effect on a
# fresh init. To rotate after first run:
#   docker compose exec postgres psql -U adc_user -c "ALTER USER adc_user PASSWORD '<new>'"
#   <edit .env to match>
#   docker compose restart adc

# Deployment mode for ADC. Docker Compose runs standalone (no leader election).
ADC_MODE=standalone

# Postgres service name on the compose network — do not change.
POSTGRES_HOST=postgres

POSTGRES_DB=adc
POSTGRES_USER=adc_user
POSTGRES_PASSWORD=change-me-before-deploying
