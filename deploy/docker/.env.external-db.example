# External PostgreSQL credentials for docker-compose.external-db.yml.
#
# Copy to .env.external-db (in this same directory) before running:
#   cp .env.external-db.example .env.external-db
#   # Edit with your real DB coordinates
#   docker compose -f docker-compose.external-db.yml up -d
#
# .env.external-db is gitignored — never commit it.
#
# These variables are loaded into the adc container and expanded by ADC's
# config loader against the ${VAR} references in config.toml.external-db.
#
# IMPORTANT: PGHOST cannot be `localhost` or `127.0.0.1` — those resolve
# inside the adc container, not on the docker host. Use one of:
#   • Your DB's public hostname (cloud DBs, recommended)
#   • host.docker.internal       (Docker Desktop on Mac/Windows)
#   • Your host's LAN IP         (Linux without Docker Desktop)

# REQUIRED. PostgreSQL hostname or IP, reachable from the adc container.
PGHOST=your-postgres-host.example.com

# REQUIRED. PostgreSQL port. Default 5432.
PGPORT=5432

# REQUIRED. Database name (must exist before first run — ADC won't create it).
POSTGRES_DB=adc

# REQUIRED. Database user with CREATE TABLE + CRUD on POSTGRES_DB.
# Provision with:
#   CREATE USER adc_user WITH PASSWORD '<strong-password>';
#   CREATE DATABASE adc OWNER adc_user;
#   \c adc
#   GRANT ALL ON SCHEMA public TO adc_user;
POSTGRES_USER=adc_user

# REQUIRED. Database password.
POSTGRES_PASSWORD=replace-with-real-password
